# =============================================================================
# 企業級工程排程 SaaS (CPM) — 環境變數範本
# 複製為 .env (cp .env.example .env) 後依需要調整。
# 欄位名稱對應 backend/app/config.py 的 snake_case 設定。
# =============================================================================

# --- 資料庫 (PostgreSQL 15, async asyncpg driver) -----------------------------
# App / Worker 一律以「非超級使用者」角色 cpm_app 連線，RLS 多租戶隔離才會真正生效。
# (cpm / cpm_password 僅為 docker-entrypoint / init.sql 使用的 bootstrap 超級使用者，
#  負責建表、RLS、種子資料並建立 cpm_app；切勿讓 App 以 cpm 連線，否則會繞過 RLS。)
DATABASE_URL=postgresql+asyncpg://cpm_app:cpm_app_password@postgres:5432/cpm_saas

# --- 快取 / 佇列 (Redis 7) ----------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- 應用程式環境 -------------------------------------------------------------
APP_ENV=development

# --- API 路由前綴 -------------------------------------------------------------
API_V1_PREFIX=/api/v1

# --- CORS 允許來源 (逗號分隔 -> list[str]) ------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- 預設區域 (TW=台灣 / CN=大陸) ---------------------------------------------
DEFAULT_REGION=TW

# --- 通知整合 (留空 => no-op / 僅記錄, 不發送網路請求) -------------------------
# LINE 推播 (台灣區域)
LINE_CHANNEL_ACCESS_TOKEN=
# 釘釘 (DingTalk) Webhook (大陸區域)
DINGTALK_WEBHOOK_URL=

# --- ERP 拋轉 Worker 設定 -----------------------------------------------------
# 掃描 sync_event_log 的間隔秒數
ERP_SCAN_INTERVAL_SECONDS=300
# 單筆事件最大重試次數 (超過 => 標記 DEAD)
ERP_MAX_RETRIES=5

# --- ERP 真實端點憑證 (留空 => 該 ERP 缺端點時走模擬模式, 不發送網路請求) -------
# 端點 URL 來自 DB (erp_integration.tenant_erp_config.api_endpoint)，以下僅為憑證。
# SAP (PS 模組) OData/REST Bearer Token
SAP_API_TOKEN=
# SAP 服務根網址 (選填; 預設不使用, 端點仍以 tenant_erp_config.api_endpoint 為準)
SAP_BASE_URL=
# 鼎新 (DINGXIN_TW) API 金鑰 (帶於 X-Api-Key 標頭)
DINGXIN_API_KEY=
# 用友 (YONYOU_CN) API 金鑰 (帶於 access_token 標頭)
YONYOU_API_KEY=

# =============================================================================
# Frontend (Vite build-time 變數) — 本地開發時使用
# 預設走 gateway 同源路徑 /api/v1; 本地直連 backend 可設為 http://localhost:8000/api/v1
# =============================================================================
VITE_API_BASE_URL=/api/v1
